{
  "args": {
    "reminder": {
      "desc": "The ID of the reminder",
      "example": "Rm23456789",
      "required": true,
      "type": "string"
    },
    "team_id": {
      "desc": "Encoded team id, required if org token is passed",
      "required": false,
      "type": "string"
    }
  },
  "desc": "Gets information about a reminder.",
  "errors": {
