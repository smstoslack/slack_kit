    "not_found": "That reminder can't be found."
  },
  "rate_limit": {
    "label": "Tier 2: 20+ per minute",
    "url": "https://docs.slack.dev/apis/web-api/rate-limits"
  },
  "scopes": {
    "user": [
      {
        "name": "reminders:read",
        "url": "https://docs.slack.dev/reference/scopes/reminders.read"
      }
    ]
  }
}

