{
  "args": {
    "canvas_id": {
      "desc": "Encoded ID of the canvas",
      "example": "F1234ABCD",
      "required": true
    },
    "criteria": {
      "desc": "Filtering criteria",
      "example": "{\"section_types\": [\"any_header\"], \"contains_text\": \"CAN Report\"}",
      "required": true
    }
  },
  "desc": "Find sections matching the provided criteria",
  "errors": {
    "canvas_deleted": "The canvas you wish to search is not available.",
    "canvas_disabled_user_team": "Canvas is disabled on user's team.",
    "canvas_not_found": "The canvas you wish to search for is not available."
  },
  "rate_limit": {
    "label": "Tier 3: 50+ per minute",
    "url": "https://docs.slack.dev/apis/web-api/rate-limits"
  },
  "scopes": {
    "bot": [
      {
        "name": "canvases:read",
        "url": "https://docs.slack.dev/reference/scopes/canvases.read"
      }
    ],
    "user": [
      {
        "name": "canvases:read",
        "url": "https://docs.slack.dev/reference/scopes/canvases.read"
      }
    ]
  }
}

