{
  "args": {
    "channel": {
      "desc": "Channel or conversation to set the read cursor for.",
      "example": "C012345678",
      "required": true,
      "type": "string"
    },
    "ts": {
      "desc": "Unique identifier of message you want marked as most recently seen in this conversation.",
      "example": "1593473566.000200",
      "required": true,
      "type": "string"
    }
  },
  "desc": "Sets the read cursor in a channel.",
  "errors": {
